@{
    ViewData["Title"] = "About Us";
}

<div class="container mt-5">

    <!-- Header -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">About Our Company</h2>
        <p class="text-muted">Delivering Secure and Innovative Financial Solutions</p>
    </div>
    <!-- Overview -->
    <div class="mb-5">
        <h4>Company Overview</h4>
        <p>
            Our organization is a forward-thinking financial technology platform committed to delivering
            secure, efficient,user-centric e-banking solutions and other finTech solutions. We specialize in digital transaction
            processing, and financial service automation, ensuring seamless interactions for individuals and businesses.
        </p>
    </div>
    <!-- Expertise -->
    <div class="mb-5">
        <h4>Our Expertise</h4>
        <p>
            As one of the most sort after consultant in financial systems and digital banking solutions, we provide robust frameworks
            that support Money Deposits, Money Withdrawals, Fund Transfers, and Loan Management. Our approach integrates
            modern technologies with E-banking industries best practices to ensure reliability, scalability, and security.
        </p>
    </div>

    <!-- Value Proposition -->
    <div class="mb-5">
        <h4>Our Value Proposition</h4>
        <ul>
            <li>✔ Secure transaction processing with advanced authentication mechanisms</li>
            <li>✔ Real-time financial operations and balance updates</li>
            <li>✔ Transparent audit trails and transaction history</li>
            <li>✔ Scalable architecture suitable for growing institutions</li>
        </ul>
    </div>

    <!-- Mission & Vision -->
    <div class="row mt-5">
        <div class="col-md-6">
            <h4>Our Mission</h4>
            <p>
                To empower users with reliable and secure financial tools that simplify everyday banking
                operations while maintaining the highest standards of data protection.
            </p>
        </div>

        <div class="col-md-6">
            <h4>Our Vision</h4>
            <p>
                To be a leading provider of digital financial solutions recognized for innovation,
                trust, and operational excellence.
            </p>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="text-center mt-5">
        <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-lg">
            Get Started With Us
        </a>
    </div>

</div>
