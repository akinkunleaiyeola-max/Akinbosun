@model ATMPOSONLINE.ViewModels.WithdrawViewModel
@{
    ViewData["Title"] = "Withdraw";
}

<div class="col-12">
    <div class="d-flex justify-content-between align-items-center mb-3">
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="text-muted">Welcome, <strong>@User.Identity.Name</strong></div>
        }

        <div>
            <a asp-controller="Transactions" asp-action="History" class="btn btn-outline-secondary btn-sm me-2">History</a>
            <a asp-controller="Transaction_Page" asp-action="Transaction" class="btn btn-secondary btn-sm">Back</a>
        </div>
    </div>
</div>

@if(TempData["Balance"] != null)
{
    <div class="alert alert-success d-flex justify-content-between align-items-center">
        <div>
            <small class="text-muted">Current Balance</small>
            <div class="fw-bold">₦@TempData["Balance"]</div>
        </div>
        <div class="text-end">
            <small class="text-muted">Available</small>
            <div class="text-success">Good standing</div>
        </div>
    </div>
}
@{
    TempData.Keep("Balance");
}

<div class="card-modern col-12 col-md-8 col-lg-6 mx-auto">
    <div class="card-header-modern d-flex align-items-center justify-content-between mb-3">
        <h4 class="mb-0">Withdraw</h4>
        <span class="text-muted small">Secure • Fast • Trackable</span>
    </div>

    <form method="post" asp-controller="Transactions" asp-action="Withdraw" class="form-card p-4">
        <div asp-validation-summary="All" class="text-danger mb-2"></div>

        <div class="mb-3">
            <label asp-for="ATMPIN" class="form-label">Your PIN</label>
            <input asp-for="ATMPIN" maxlength="4" type="password" inputmode="numeric" pattern="[0-9]*" class="form-control form-control-lg" aria-describedby="pinHelp" />
            <div id="pinHelp" class="form-text">Enter your 4-digit ATM PIN.</div>
            <span asp-validation-for="ATMPIN" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Amount" class="form-label">Amount</label>
            <div class="input-group input-group-lg">
                <span class="input-group-text">₦</span>
                <input asp-for="Amount" type="number" step="0.01" min="0" class="form-control" id="amountInput" placeholder="0.00" aria-label="Amount to withdraw" />
            </div>
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <div class="quick-amounts d-flex gap-2 flex-wrap">
                <button type="button" class="btn btn-outline-secondary btn-sm quick" data-amount="5000">₦5,000</button>
                <button type="button" class="btn btn-outline-secondary btn-sm quick" data-amount="10000">₦10,000</button>
                <button type="button" class="btn btn-outline-secondary btn-sm quick" data-amount="20000">₦20,000</button>
                <button type="button" class="btn btn-outline-secondary btn-sm quick" data-amount="50000">₦50,000</button>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Description (optional)</label>
            <input asp-for="Description" class="form-control" placeholder="e.g., ATM withdrawal" />
        </div>

        <div class="d-grid gap-2">
            <button class="btn btn-primary btn-lg" type="submit">Withdraw</button>
            <a asp-controller="Transaction_Page" asp-action="Transaction" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        (function () {
            document.querySelectorAll('.quick-amounts .quick').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var amt = this.getAttribute('data-amount');
                    var input = document.getElementById('amountInput');
                    if (input) input.value = amt;
                });
            });

            // simple input formatting for desktop UX
            var amtInput = document.getElementById('amountInput');
            if (amtInput) {
                amtInput.addEventListener('input', function () {
                    // remove non-numeric except dot
                    this.value = this.value.replace(/[^0-9.]/g, '');
                });
            }
        })();
    </script>
}
