@model ATMPOSONLINE.ViewModels.TransferViewModel;

<div class="d-flex justify-content-between align-items-center">
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <h6>Welcome, @User.Identity.Name</h6>
    }
</div>
@if (TempData["Balance"] != null)
{
    <div class="alert alert-success">
        New Balance: ₦@TempData["Balance"]
    </div>
}
@{
    TempData.Keep("Balance");
 }
<div asp-validation-summary="All" class="text-danger"></div>
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-lg p-4"> 
            <form method="post" asp-action="GetAccountName">
                <div asp-validation-summary="All" class="text-danger"></div>
                <!-- Receiver Account -->
                <div class="mb-3">
                    <label asp-for="ReceiverAccountNumber" class="form-label fw-semibold">Receiver Account Number</label>
                    <input asp-for="ReceiverAccountNumber" id="RecieverAccountNumber" class="form-control" required placeholder="Reciever Account Number" />
                </div>
                <!-- Auto Name -->
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold">Receiver Name</label>
                    <input asp-for="FullName" id="FullName" class="form-control" readonly required placeholder="Full Name" />
                </div>
                <!-- Amount -->
                <div class="mb-3">
                    <label asp-for="Amount" class="form-label fw-semibold">Amount</label>
                    <input asp-for="Amount" class="form-control" required placeholder="Enter amount" />
                </div>
                <!-- PIN -->
                <div class="mb-3">
                    <label asp-for="ATMPIN" class="form-label fw-semibold">PIN</label>
                    <input asp-for="ATMPIN" type="password" class="form-control" />
                </div>
                <button class="btn btn-success w-100">Transfer</button>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const accountInput = document.getElementById("ReceiverAccountNumber");
            const fullNameInput = document.getElementById("FullName");

            accountInput.addEventListener("input", function () {

                let accountNumber = accountInput.value;

                if (accountNumber.length >= 10) {

                    fullNameInput.value = "Checking...";

                    fetch('/Transactions/GetFullAccountName?accountNumber=' + accountNumber)
                        .then(response => response.json())
                        .then(data => {
                            fullNameInput.value = data ? data : "Account not found";
                        })
                        .catch(() => {
                            fullNameInput.value = "Error";
                        });

                } else {
                    fullNameInput.value = "";
                }
            });

        });
    </script>
}


