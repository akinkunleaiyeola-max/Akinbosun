@model ATMPOSONLINE.ViewModels.TransferViewModel
@{
    ViewData["Title"] = "Transfer";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="text-muted">Welcome, <strong>@User.Identity.Name</strong></div>
    }

    <div>
        <a asp-controller="Transactions" asp-action="History" class="btn btn-outline-secondary btn-sm">History</a>
    </div>
</div>

@if (TempData["Balance"] != null)
{
    <div class="alert alert-success d-flex justify-content-between align-items-center">
        <div>
            <small class="text-muted">Current Balance</small>
            <div class="fw-bold">₦@TempData["Balance"]</div>
        </div>
    </div>
}
@{
    TempData.Keep("Balance");
}

<div class="card-modern col-12 col-md-8 col-lg-6 mx-auto">
    <div class="card-header-modern d-flex align-items-center justify-content-between mb-3">
        <h4 class="mb-0">Transfer Money</h4>
        <small class="text-muted">Fast • Secure • Tracked</small>
    </div>

    <form method="post" asp-controller="Transactions" asp-action="Transfer" class="form-card">
        <div asp-validation-summary="All" class="text-danger mb-2"></div>
        <div class="mb-3">
            <label asp-for="ReceiverAccountNumber" class="form-label">Recipient account</label>
            <input asp-for="ReceiverAccountNumber" id="ReceiverAccountNumber" class="form-control form-control-lg" placeholder="Enter recipient account number" />
            <span asp-validation-for="ReceiverAccountNumber" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="FullName" class="form-label">Recipient name</label>
            <input asp-for="FullName" id="FullName" class="form-control form-control-lg" readonly />
        </div>
        <div class="mb-3">
            <label asp-for="Amount" class="form-label">Amount</label>
            <div class="input-group input-group-lg">
                <span class="input-group-text">₦</span>
                <input asp-for="Amount" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
            </div>
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <div class="quick-amounts d-flex gap-2 flex-wrap">
                <button type="button" class="btn btn-outline-secondary btn-sm quick" data-amount="5000">₦5,000</button>
                <button type="button" class="btn btn-outline-secondary btn-sm quick" data-amount="10000">₦10,000</button>
                <button type="button" class="btn btn-outline-secondary btn-sm quick" data-amount="20000">₦20,000</button>
                <button type="button" class="btn btn-outline-secondary btn-sm quick" data-amount="50000">₦50,000</button>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <input asp-for="Description" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="ATMPIN" class="form-label">PIN</label>
            <input asp-for="ATMPIN" maxlength="4" type="password" inputmode="numeric" pattern="[0-9]*" class="form-control form-control-lg" aria-describedby="pinHelp" />
            <span asp-validation-for="ATMPIN" class="text-danger"></span>
        </div>

        <div class="d-grid gap-2">
            <button class="btn btn-primary btn-lg">Transfer</button>
            <a asp-controller="Transaction_Page" asp-action="Transaction" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const accountInput = document.getElementById("ReceiverAccountNumber");
            const fullNameInput = document.getElementById("FullName");
            const quickButtons = document.querySelectorAll('.quick-amounts .quick');

            if (accountInput) {
                accountInput.addEventListener("keyup", function () {
                    let accountNumber = accountInput.value;
                    if (accountNumber.length >= 10) {
                        fullNameInput.value = "Checking...";
                        fetch('/Transactions/GetAccountName?accountNumber=' + encodeURIComponent(accountNumber))
                            .then(r => r.json())
                            .then(data => fullNameInput.value = data || "Account not found")
                            .catch(() => fullNameInput.value = "Error");
                    } else {
                        fullNameInput.value = "";
                    }
                });
            }

            quickButtons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var amt = this.getAttribute('data-amount');
                    var input = document.querySelector('input[name="Amount"]');
                    if (input) input.value = amt;
                });
            });
        });
    </script>
}



