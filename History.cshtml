@model List<ATMPOSONLINE.Models.Transactions>

@{
    ViewData["Title"] = "Transaction History";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Transaction History</h2>
    <div>
        <a asp-controller="Transaction_Page" asp-action="Transaction" class="btn btn-outline-secondary btn-sm">Back</a>
    </div>
</div>
<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th class="text-end">Amount (₦)</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.Date.ToString("g")</td>
                    <td>
                        <span class="badge rounded-pill @(t.Type == "Credit" ? "bg-success" : "bg-secondary")">@t.Type</span>
                    </td>
                    <td class="text-end">₦@t.Amount.ToString("N2")</td>
                    <td>@t.Description</td>
                </tr>
            }
        </tbody>
    </table>
    <button onclick="window.print()" class="btn btn-primary">
        🖨️ Print Receipt
    </button>
</div>
