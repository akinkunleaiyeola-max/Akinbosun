

@{
    ViewData["Title"] = "About Us";
}

<div class="container mt-5">

    <!-- Page Title -->
    <div class="text-center mb-5">
        <h2 class="fw-bold">About Our Company</h2>
        <p class="text-muted">Secure Banking Made Simple</p>
    </div>
    <!-- About Section -->
    <div class="row">
        <div class="col-md-6">
            <h4>Who We Are</h4>
            <p>
                We are a modern digital banking platform designed to provide secure,
                fast, and reliable e-channel banking services. Our system enables users to
                perform Cash Deposits, Cash Withdrawals, Cash Transfers, and Loan applications with ease.
            </p>
        </div>
        <div class="col-md-6">
            <img src="/images/ku.jpg" class="img-fluid rounded shadow" alt="Bank Image" />
        </div>
    </div>
    <!-- Mission & Vision -->
    <div class="row mt-5">
        <div class="col-md-6">
            <h4>Our Mission</h4>
            <p>
                To provide a secure and user-friendly banking experience powered by
                modern technology.
            </p>
        </div>

        <div class="col-md-6">
            <h4>Our Vision</h4>
            <p>
                To become a leading digital banking platform trusted by users worldwide.
            </p>
        </div>
    </div>
    <!-- Features -->
    <div class="mt-5">
        <h4 class="text-center mb-4">Our Services</h4>
        <div class="row text-center">
            <div class="col-md-3">
                <div class="card p-3 shadow-sm">
                    <h5>💰 Deposits</h5>
                    <p>Quick and secure money deposits</p>
                      <a asp-controller="Account" asp-action="Register" class="btn btn-outline-warning btn-lg">You can register on our platform by clicking the button</a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 shadow-sm">
                    <h5>💸 Transfers</h5>
                    <p>Send money instantly</p>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-success btn-lg">You can register on our platform by clicking the button</a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 shadow-sm">
                    <h5>🏧 Withdrawals</h5>
                    <p>Fast ATM-style withdrawals</p>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg">You can register on our platform by clicking the button</a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 shadow-sm">
                    <h5>📄 Loans</h5>
                    <p>Easy loan application & approval</p>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-dark btn-lg">You can register on our platform by clicking the button</a>
                </div>
            </div>
        </div>
    </div>
</div>
